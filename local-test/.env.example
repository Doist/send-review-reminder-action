# Local test config for send-review-reminder-action.
# Copy this file to local-test/.env.local and fill it in.
# .env.local is git-ignored — do NOT put real secrets in this example file.

# --- Comms (used by both harnesses) ---
# Todoist API token of the user who will post to Comms.
# View and copy it at https://app.todoist.com/app/settings/integrations/developer
TODOIST_API_TOKEN=
# The Comms thread id to post into
THREAD_ID=

# Optional smoke-test overrides:
# Comma-separated numeric Comms user ids to notify (e.g. 647098,123456)
RECIPIENTS=
# The message body the smoke test will post
CONTENT='Local smoke test from send-review-reminder-action'

# --- Full action run only (run-action-locally.sh) ---
# A GitHub token with repo read access, and the repo to scan.
GITHUB_TOKEN=
GITHUB_REPOSITORY=
REVIEW_TIME_MS=86400000
MESSAGE='%reviewer%, please review [#%pr_number% - %pr_title%](%pr_url%)'
IGNORE_AUTHORS=
IGNORE_DRAFT_PRS=true
IGNORE_LABELS=
IGNORE_PRS_WITH_FAILING_CHECKS=true
AUTHOR_TO_COMMS_MAPPING=
IGNORE_REVIEW_BOTS=github-actions
